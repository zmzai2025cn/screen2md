# Screen2MD Enterprise - Wine测试容器
# 解决Linux/Windows兼容性问题的测试环境

FROM ubuntu:22.04

# 避免交互式配置
ENV DEBIAN_FRONTEND=noninteractive

# 安装基础依赖
RUN dpkg --add-architecture i386 \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        software-properties-common \
        wget \
        curl \
        ca-certificates \
        gnupg2 \
        wine64 \
        wine32 \
        winetricks \
        xvfb \
        x11-apps \
        fluxbox \
        python3 \
        python3-pip \
        python3-venv \
        dotnet-runtime-8.0 \
        p7zip-full \
        cabextract \
        unzip \
    && rm -rf /var/lib/apt/lists/*

# 配置 Wine 环境
ENV WINEARCH=win64
ENV WINEPREFIX=/root/.wine
ENV DISPLAY=:99

# 初始化 Wine (静默)
RUN wine --version 2>/dev/null || true

# 安装核心字体和基本组件
RUN winetricks -q corefonts msxml6 riched20 2>/dev/null || true

# 创建虚拟显示目录
RUN mkdir -p /tmp/.X11-unix /results /app

# 设置工作目录
WORKDIR /app

# 复制测试脚本
COPY scripts/ /opt/scripts/
RUN chmod +x /opt/scripts/*.sh

# 复制测试代理
COPY test-agent/ /opt/test-agent/
RUN pip3 install --no-cache-dir -r /opt/test-agent/requirements.txt 2>/dev/null || true

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD pgrep -f "Screen2MD" || exit 1

# 入口脚本
ENTRYPOINT ["/opt/scripts/start-test-env.sh"]
CMD ["--help"]
